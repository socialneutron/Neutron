# Neutron Backend Environment Variables
# Copy this file to .env and fill in your real values

# ─── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ───────────────────────────────────────────────────
# Get this from: MongoDB Atlas > Connect > Connect your application
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/neutron?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_64_byte_hex
JWT_REFRESH_SECRET=replace_with_different_random_64_byte_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_EMAIL_VERIFY_EXPIRES=24h
JWT_PASSWORD_RESET_EXPIRES=1h

# ─── Cloudinary ──────────────────────────────────────────────────────
# Get from: cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Redis ───────────────────────────────────────────────────────────
# Local Redis: redis://localhost:6379
# Redis Cloud: redis://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# ─── Email (SMTP) ────────────────────────────────────────────────────
# For Gmail: Enable 2FA > App Passwords > Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Neutron <noreply@neutron.app>"

# ─── Frontend ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# For production: FRONTEND_URL=https://your-domain.com

# ─── Security ────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# How many login attempts before lockout
ACCOUNT_LOCKOUT_THRESHOLD=5
# Lockout duration in ms (15 minutes)
ACCOUNT_LOCKOUT_DURATION=900000

# ─── Rate Limiting ───────────────────────────────────────────────────
# General: 100 requests per 15 minutes per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Auth endpoints: 10 attempts per 15 minutes
AUTH_RATE_LIMIT_MAX=10

# ─── Admin ───────────────────────────────────────────────────────────
# The email that gets promoted to admin on first registration
ADMIN_EMAIL=admin@neutron.app
